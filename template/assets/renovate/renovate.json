{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "description": "Isolate Python engine upgrades from general dependency groups",
      "matchPackageNames": [
        "python"
      ],
      "groupName": "python-version"
    }
  ]
}
