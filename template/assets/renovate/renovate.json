{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "python"
      ],
      "groupName": "python-version"
    },
    {
      "matchPackageNames": [
        "go",
        "golang"
      ],
      "groupName": "go-version"
    },
    {
      "matchPackageNames": [
        "rust",
        "rust-lang/rust"
      ],
      "groupName": "rust-version"
    }
  ]
}
